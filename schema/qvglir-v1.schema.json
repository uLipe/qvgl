{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qvgl.dev/schema/qvglir-v1.schema.json",
  "title": "QVGL IR v1 (JSON dump)",
  "description": "Debug interchange format; canonical artifact is binary .qvglir. See docs/04-ir-schema.md.",
  "type": "object",
  "required": ["version", "profile", "module", "root", "nodes"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "module": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "root": { "type": "integer", "minimum": 0 },
    "module_properties": {
      "type": "array",
      "items": { "$ref": "#/$defs/module_property" }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/binding" }
    },
    "handlers": {
      "type": "array",
      "items": { "$ref": "#/$defs/handler" }
    }
  },
  "$defs": {
    "module_property": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "enum": ["bool", "i32", "f32", "string", "color"] },
        "default": {}
      }
    },
    "node": {
      "type": "object",
      "required": ["kind", "children", "properties"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kind": {
          "enum": [
            "Item",
            "Rectangle",
            "Text",
            "Image",
            "Arc",
            "Meter",
            "MouseArea"
          ]
        },
        "children": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/property_value"
          }
        },
        "flags": {
          "type": "array",
          "items": {
            "enum": ["static_layout", "needs_observer"]
          }
        }
      }
    },
    "property_value": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "integer" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "object",
          "required": ["binding"],
          "properties": {
            "binding": { "$ref": "#/$defs/expr" }
          },
          "additionalProperties": false
        }
      ]
    },
    "binding": {
      "type": "object",
      "required": ["target", "key", "expr"],
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string", "description": "node id" },
        "key": { "type": "string" },
        "expr": { "$ref": "#/$defs/expr" }
      }
    },
    "handler": {
      "type": "object",
      "required": ["node", "signal", "handler"],
      "additionalProperties": false,
      "properties": {
        "node": { "type": "string", "description": "node id" },
        "signal": { "type": "string" },
        "handler": {
          "type": "string",
          "description": "C callback symbol implemented by application"
        }
      }
    },
    "expr": {
      "oneOf": [
        {
          "type": "object",
          "required": ["sym"],
          "properties": {
            "sym": {
              "type": "string",
              "description": "module property or id.property"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["const"],
          "properties": {
            "const": { "type": ["number", "string", "boolean"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["op", "args"],
          "properties": {
            "op": {
              "enum": [
                "add",
                "sub",
                "mul",
                "ternary",
                "map_linear",
                "format"
              ]
            },
            "args": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
